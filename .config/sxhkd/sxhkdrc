# sxhkdrc
#
# Author: Rafael Cavalcanti <https://rafaelc.org/dev>

super + b
  blueman-manager

{super + c, XF86Calculator}
  gnome-calculator

super + shift + d
  theme-mode-xsettingsd toggle

super + e
  $TERMINAL -e nvim

super + {_, shift} + f
  { \
    $TERMINAL -e lf, \
    nemo \
  }

super + g
  networkmanager_dmenu

super + {_, shift, ctrl } + n
  dunstctl { \
    close, \
    history-pop, \
    context; dunstctl close \
  }

super + o
  dmenu-document

super + p
  keepassxc

super + shift + q
  xkill

super + r
  dmenu-radio

super + s
  obsidian

super + u
  $TERMINAL -n cmus -e cmus

# Arguments:
# -i: unneded with patched dmenu to case insensitve, but necessary using rofi.
# -theme-str: configure rofi theme.
super + {_, shift} + v
  { \
    clipmenu -i -theme-str "listview \{ columns: 1; \}", \
    dmenu-emoji insert \
  }

super + w
  $BROWSER

super + y
  dmenu-yt

super + Return
  $TERMINAL

Print + {_, shift}
  flameshot gui {_, --delay 5000}


######################
##   DWM SPECIFIC   ##
######################

super + d
  rofi -show drun -show-icons

super + shift + r
  killall -HUP dwm

{super + shift + BackSpace, XF86ScreenSaver }
  slock

ctrl + alt + Delete
  dmenu-power
